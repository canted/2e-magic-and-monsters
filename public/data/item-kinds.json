{"version":1,"description":"Broad magic item kinds used by generated AD&D 2e app data. Match terms are applied to item type, wiki categories, and item name, then emitted as reusable itemKinds on each record.","fallback":{"id":"other-oddities","label":"Other / Oddities","description":"Items that do not clearly fit one of the broader equipment, consumable, or relic families."},"kinds":[{"id":"weapons","label":"Weapons","description":"Arms and offensive implements, including named weapon families and ammunition.","match":{"itemType":["Ammunition","Arrow","Axe","Blade","Bolt","Bow","Club","Dagger","Dart","Flail","Hammer","Javelin","Knife","Lance","Mace","Missile Weapon","Polearm","Sling","Spear","Staff-Sling","Sword","Trident","Weapon"],"categories":["Magic Ammunition","Magic Arrows","Magic Axes","Magic Bows","Magic Daggers","Magic Maces","Magic Swords","Magic Weapons","Weapon Enhancements"],"name":["Ammunition","Arrow","Axe","Blade","Bolt","Bow","Dagger","Javelin","Mace","Spear","Sword","Weapon"]}},{"id":"armor-shields","label":"Armor & Shields","description":"Defensive armor, shields, helms, and closely related protective gear.","match":{"itemType":["Armor","Armour","Breastplate","Buckler","Chain Mail","Helm","Helmet","Plate Mail","Scale Mail","Shield"],"categories":["Magic Armor","Magic Armour","Magic Helmets","Magic Helms","Magic Shields"],"name":["Armor","Armour","Helm","Helmet","Shield"]}},{"id":"potions-oils-powders","label":"Potions, Oils & Powders","description":"Consumable liquids, powders, dusts, incense, ointments, and similar preparations.","match":{"itemType":["Dust","Elixir","Incense","Oil","Ointment","Perfume","Philter","Potion","Powder","Salve"],"categories":["Magic Dusts","Magic Elixirs","Magic Incense","Magic Oils","Magic Ointments","Magic Philtres","Magic Philters","Magic Potions","Magic Powders"],"name":["Dust","Elixir","Incense","Oil","Ointment","Perfume","Philter","Potion","Powder","Salve"]}},{"id":"rings","label":"Rings","description":"Magic rings and ring-like hand jewelry.","match":{"itemType":["Ring"],"categories":["Magic Rings"],"name":["Ring"]}},{"id":"rods-staves-wands","label":"Rods, Staves & Wands","description":"Charged or command-word implements held and used like rods, staves, sceptres, or wands.","match":{"itemType":["Rod","Scepter","Sceptre","Staff","Staves","Wand"],"categories":["Magic Rods","Magic Scepters","Magic Sceptres","Magic Staves","Magic Staffs","Magic Wands"],"name":["Rod","Scepter","Sceptre","Staff","Staves","Wand"]}},{"id":"scrolls-books-spell-storage","label":"Scrolls, Books & Spell Storage","description":"Written magic, spell containers, spellbooks, manuals, tomes, tablets, and similar lore objects.","match":{"itemType":["Book","Folio","Grimoire","Libram","Manual","Scroll","Spellbook","Tablet","Tome"],"categories":["Magic Books","Magic Librams","Magic Manuals","Magic Scrolls","Magic Spellbooks","Magic Tablets","Magic Tomes"],"name":["Book","Folio","Grimoire","Libram","Manual","Scroll","Spellbook","Tablet","Tome"]}},{"id":"worn-gear-clothing","label":"Worn Gear & Clothing","description":"Wearable magic that is not primarily armor or jewelry.","match":{"itemType":["Belt","Boots","Bracers","Cap","Cloak","Clothing","Gauntlets","Girdle","Gloves","Hat","Mantle","Mask","Robe","Sandals","Shirt","Slippers","Vest"],"categories":["Magic Belts","Magic Boots","Magic Bracers","Magic Caps","Magic Cloaks","Magic Clothing","Magic Gauntlets","Magic Girdles","Magic Gloves","Magic Hats","Magic Masks","Magic Robes","Magic Sandals","Magic Slippers"],"name":["Belt","Boots","Bracers","Cap","Cloak","Gauntlets","Girdle","Gloves","Hat","Mantle","Mask","Robe","Sandals","Slippers","Vest"]}},{"id":"jewelry-adornments","label":"Jewelry & Adornments","description":"Amulets, brooches, gems, jewels, crowns, medallions, and other decorative worn objects.","match":{"itemType":["Amulet","Bead","Bracelet","Brooch","Charm","Circlet","Crown","Diadem","Earring","Gem","Jewel","Medallion","Necklace","Pendant","Phylactery","Pin","Scarab","Torc"],"categories":["Magic Amulets","Magic Beads","Magic Bracelets","Magic Brooches","Magic Charms","Magic Crowns","Magic Gems","Magic Jewels","Magic Medallions","Magic Necklaces","Magic Scarabs"],"name":["Amulet","Bead","Bracelet","Brooch","Charm","Circlet","Crown","Diadem","Earring","Gem","Jewel","Medallion","Necklace","Pendant","Phylactery","Pin","Scarab","Torc"]}},{"id":"containers-storage","label":"Containers & Storage","description":"Containers, vessels, quivers, bags, chests, bottles, portable holes, and storage objects.","match":{"itemType":["Bag","Bottle","Box","Case","Chest","Coffer","Container","Flask","Hole","Jar","Jug","Pouch","Quiver","Vial"],"categories":["Magic Bags","Magic Bottles","Magic Boxes","Magic Chests","Magic Containers","Magic Flasks","Magic Jugs","Magic Pouches","Magic Quivers"],"name":["Bag","Bottle","Box","Case","Chest","Coffer","Flask","Jar","Jug","Portable Hole","Pouch","Quiver","Vial"]}},{"id":"tools-devices","label":"Tools & Devices","description":"Implements, instruments, devices, figurines, lenses, mirrors, stones, orbs, keys, ropes, and utility objects.","match":{"itemType":["Abacus","Apparatus","Bowl","Brush","Candle","Card","Cauldron","Cube","Deck","Device","Eye","Figurine","Horn","Instrument","Key","Lamp","Lantern","Lens","Lock","Mirror","Orb","Pipe","Rope","Stone","Tool","Whistle"],"categories":["Magic Apparatuses","Magic Bowls","Magic Candles","Magic Cards","Magic Cauldrons","Magic Decks","Magic Devices","Magic Figurines","Magic Horns","Magic Instruments","Magic Keys","Magic Lamps","Magic Lanterns","Magic Lenses","Magic Mirrors","Magic Orbs","Magic Ropes","Magic Stones","Magic Tools"],"name":["Abacus","Apparatus","Bowl","Brush","Candle","Card","Cauldron","Cube","Deck","Device","Eye","Figurine","Horn","Instrument","Key","Lamp","Lantern","Lens","Lock","Mirror","Orb","Pipe","Rope","Stone","Tool","Whistle"]}},{"id":"travel-vehicles","label":"Travel & Vehicles","description":"Objects that primarily carry, mount, 